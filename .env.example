
# ==============================================================================
# Honeypot Threat Intelligence Platform — Environment Configuration
# Generated: Production Deployment on Oracle Cloud
# ==============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# ELASTIC STACK VERSION
# ─────────────────────────────────────────────────────────────────────────────
ELASTIC_VERSION=9.0.2

# ─────────────────────────────────────────────────────────────────────────────
# ELASTICSEARCH CREDENTIALS (Strong Passwords Generated)
# ─────────────────────────────────────────────────────────────────────────────
ELASTIC_USER=elastic
ELASTIC_PASSWORD=CHANGE_ME_RANDOM_STRING

KIBANA_PASSWORD=CHANGE_ME_RANDOM_STRING
KIBANA_SYSTEM_PASSWORD=CHANGE_ME_RANDOM_STRING
LOGSTASH_INTERNAL_PASSWORD=CHANGE_ME_RANDOM_STRING

# ─────────────────────────────────────────────────────────────────────────────
# ELASTICSEARCH CONNECTION STRINGS (Docker internal hostnames)
# ─────────────────────────────────────────────────────────────────────────────
ELASTICSEARCH_HOSTS=http://elasticsearch:9200
ELASTICSEARCH_URL=http://elasticsearch:9200

# ─────────────────────────────────────────────────────────────────────────────
# JVM HEAP SIZES (Oracle Free Tier: 24GB RAM, using 4GB for ES + LS)
# ─────────────────────────────────────────────────────────────────────────────
# Reduced heaps to avoid startup kills on constrained or bursting environments.
ES_JAVA_OPTS=-Xms1g -Xmx1g
LS_JAVA_OPTS=-Xms256m -Xmx256m

# ─────────────────────────────────────────────────────────────────────────────
# DOCKER NETWORK
# ─────────────────────────────────────────────────────────────────────────────
NETWORK_NAME=honeypot-network
# Use a higher non-overlapping private range for this environment
SUBNET=10.200.0.0/16

# ─────────────────────────────────────────────────────────────────────────────
# HOST PORT MAPPINGS
# ─────────────────────────────────────────────────────────────────────────────

# ELK Stack Ports
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601
LOGSTASH_BEATS_PORT=5044
LOGSTASH_API_PORT=9600

# Web Dashboard Port
WEBAPP_PORT=5000

# Cowrie SSH/Telnet Honeypot Ports
COWRIE_SSH_PORT=2222
COWRIE_TELNET_PORT=2223

# Dionaea Multi-Protocol Honeypot Ports
DIONAEA_FTP_PORT=2121
DIONAEA_DAYTIME_PORT=4042
DIONAEA_RPC_PORT=4135
DIONAEA_HTTPS_PORT=4443
DIONAEA_SMB_PORT=4445
DIONAEA_MSSQL_PORT=4433
DIONAEA_MYSQL_PORT=4306
DIONAEA_SIP_PORT=5060
DIONAEA_SIPS_PORT=5061

# Flask HTTP Honeypot Port
FLASK_HTTP_PORT=8181

# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION SETTINGS
# ─────────────────────────────────────────────────────────────────────────────
FLASK_ENV=production
FLASK_DEBUG=0
TZ=UTC
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30

# ─────────────────────────────────────────────────────────────────────────────
# WEBAPP AUTHENTICATION (SQLite + Flask session)
# ─────────────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=CHANGE_ME_RANDOM_STRING
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=change-me-admin-password